rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'hokkyjoshua@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.full_name is string && data.full_name.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.phone_number is string && data.phone_number.size() <= 20 &&
               data.category in ['student', 'parent', 'teacher', 'public'] &&
               data.role in ['user', 'admin'] &&
               (!('school_name' in data) || data.school_name == null || (data.school_name is string && data.school_name.size() <= 200));
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || request.auth.token.email == 'hokkyjoshua@gmail.com');
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || request.auth.token.email == 'hokkyjoshua@gmail.com') && 
                      request.resource.data.email == resource.data.email; 
      allow delete: if isAdmin();
    }

    // 2. Schools Collection
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 3. SPPGs Collection
    match /sppgs/{sppgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 4. Reports Collection
    match /reports/{reportId} {
       function isValidReport(data) {
         return (data.user_id == 'anonymous' || (isSignedIn() && data.user_id == request.auth.uid)) &&
                data.school_name is string && data.school_name.size() <= 200 &&
                data.sppg_name is string && data.sppg_name.size() <= 200 &&
                (!('school_id' in data) || data.school_id == null || (data.school_id is string && data.school_id.size() <= 128)) &&
                (!('sppg_id' in data) || data.sppg_id == null || (data.sppg_id is string && data.sppg_id.size() <= 128)) &&
                data.rating is number && data.rating >= 1 && data.rating <= 5 &&
                data.status in ['pending', 'reviewed', 'completed'] &&
                data.province is string &&
                data.city is string &&
                data.created_at is string &&
                (!('complaint' in data) || (data.complaint is string && data.complaint.size() <= 2000)) &&
                (!('admin_note' in data) || (data.admin_note is string && data.admin_note.size() <= 2000));
       }

      allow list: if isSignedIn() && (isAdmin() || resource.data.user_id == request.auth.uid);
      allow get: if (isSignedIn() && (isAdmin() || resource.data.user_id == request.auth.uid));
      allow create: if isValidReport(request.resource.data) && 
                       request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
